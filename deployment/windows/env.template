# Archivo base para la instalación de Open ArchiBook LLM en Windows
# Se copiará automáticamente a deployment/windows/runtime/settings.env

APP_NAME=Open ArchiBook LLM
FRONTEND_PORT=8502
API_PORT=5055
SURREAL_PORT=8000

# Credenciales de la aplicación y cifrado
OPEN_NOTEBOOK_PASSWORD=
OPEN_NOTEBOOK_ENCRYPTION_KEY=

# Credenciales internas de SurrealDB
SURREAL_ROOT_USER=open_notebook
SURREAL_ROOT_PASSWORD=
SURREAL_NAMESPACE=open_notebook
SURREAL_DATABASE=open_notebook

OPEN_NOTEBOOK_ALLOWED_ORIGINS=http://localhost:8502,http://127.0.0.1:8502
OPEN_NOTEBOOK_PUBLIC_DOCS=false
OPEN_NOTEBOOK_ENABLE_UPDATE_CHECK=false
OPEN_NOTEBOOK_TRUST_PROXY_HEADERS=false
OPEN_NOTEBOOK_AUTH_MAX_ATTEMPTS=10
OPEN_NOTEBOOK_AUTH_WINDOW_SECONDS=300
OPEN_NOTEBOOK_AUTH_BLOCK_SECONDS=600
OPEN_NOTEBOOK_AUTH_FAILURE_DELAY_MS=400
OPEN_NOTEBOOK_MAX_UPLOAD_BYTES=52428800
OPEN_NOTEBOOK_ALLOW_PRIVATE_SOURCE_URLS=false

# URL de Ollama vista desde este ordenador
HOST_OLLAMA_URL=http://localhost:11434

# URL de Ollama vista desde dentro del contenedor Docker
OLLAMA_API_BASE=http://host.docker.internal:11434

# Opcional: endpoint compatible con OpenAI en red local o privada
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_API_KEY=
