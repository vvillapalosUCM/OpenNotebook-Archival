# Copy this file to .env before running docker compose up -d --build

FRONTEND_PORT=8502
API_PORT=5055

# Required secrets
OPEN_NOTEBOOK_ENCRYPTION_KEY=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
OPEN_NOTEBOOK_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD

# Internal database credentials
SURREAL_ROOT_USER=open_notebook
SURREAL_ROOT_PASSWORD=CHANGE_ME_TO_A_LONG_RANDOM_DB_PASSWORD
SURREAL_NAMESPACE=open_notebook
SURREAL_DATABASE=open_notebook

# Network and hardening
OPEN_NOTEBOOK_ALLOWED_ORIGINS=http://localhost:8502,http://127.0.0.1:8502
OPEN_NOTEBOOK_PUBLIC_DOCS=false
OPEN_NOTEBOOK_ENABLE_UPDATE_CHECK=false
OPEN_NOTEBOOK_TRUST_PROXY_HEADERS=false
OPEN_NOTEBOOK_ALLOW_PRIVATE_SOURCE_URLS=false

# Authentication hardening
OPEN_NOTEBOOK_AUTH_MAX_ATTEMPTS=10
OPEN_NOTEBOOK_AUTH_WINDOW_SECONDS=300
OPEN_NOTEBOOK_AUTH_BLOCK_SECONDS=600
OPEN_NOTEBOOK_AUTH_FAILURE_DELAY_MS=400

# Upload limit in bytes
OPEN_NOTEBOOK_MAX_UPLOAD_BYTES=52428800

# Local model endpoints
OLLAMA_API_BASE=http://host.docker.internal:11434
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_API_KEY=

# Version check target for this fork
OPEN_NOTEBOOK_VERSION_REPOSITORY_URL=https://github.com/vvillapalosUCM/OpenNotebook-Archival
OPEN_NOTEBOOK_VERSION_REPOSITORY_BRANCH=main
