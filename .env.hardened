# ============================================================================
# OpenNotebook Archival — Variables de Entorno (Despliegue Endurecido)
# ============================================================================
# INSTRUCCIONES:
#   1. Copiar este fichero como ".env" en la misma carpeta que docker-compose.yml
#   2. CAMBIAR OBLIGATORIAMENTE los valores marcados con ⚠️
#   3. Revisar los valores opcionales según tu configuración
#   4. NO subir este fichero a ningún repositorio (incluido en .gitignore)
#
# NOTA: Los nombres de variables son idénticos en este fichero y en
# deployment/windows/env.template. Si cambias algo aquí, comprueba
# que el template de Windows sigue siendo coherente.
# ============================================================================


# ============================================================================
# ⚠️  OBLIGATORIO — CAMBIAR ANTES DEL PRIMER ARRANQUE
# ============================================================================

# Clave de cifrado para las credenciales de proveedores IA almacenadas en BD.
# Se usa para AES-128-CBC + HMAC-SHA256 (Fernet). Si se pierde, las API keys
# guardadas en la BD quedan irrecuperables.
# Generar con:  python -c "import secrets; print(secrets.token_urlsafe(32))"
# O en PowerShell:  [Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Max 256 }) -as [byte[]])
OPEN_NOTEBOOK_ENCRYPTION_KEY=⚠️_CAMBIAR_ESTO_cadena_aleatoria_de_32_caracteres_minimo

# Contraseña de acceso a la aplicación (protege frontend + API).
# Si se deja vacía, la aplicación arranca SIN autenticación.
# Generar con:  python -c "import secrets; print(secrets.token_urlsafe(16))"
OPEN_NOTEBOOK_PASSWORD=⚠️_CAMBIAR_ESTO_contraseña_de_acceso

# Usuario administrador de SurrealDB (NO usar "root")
SURREAL_ROOT_USER=on_admin

# Contraseña de SurrealDB (NO usar "root")
# Generar con:  python -c "import secrets; print(secrets.token_urlsafe(24))"
SURREAL_ROOT_PASSWORD=⚠️_CAMBIAR_ESTO_contraseña_fuerte


# ============================================================================
# BASE DE DATOS — No modificar salvo necesidad
# ============================================================================

SURREAL_NAMESPACE=open_notebook
SURREAL_DATABASE=open_notebook


# ============================================================================
# PUERTOS LOCALES — Solo 127.0.0.1 (definido en docker-compose.yml)
# ============================================================================
# Modificar solo si hay conflicto con otros servicios locales.

FRONTEND_PORT=8502
API_PORT=5055


# ============================================================================
# SEGURIDAD DE RED Y CORS
# ============================================================================

# Orígenes permitidos para peticiones CORS (separados por coma).
# Deben coincidir con el puerto del frontend.
OPEN_NOTEBOOK_ALLOWED_ORIGINS=http://localhost:8502,http://127.0.0.1:8502

# Documentación de la API (Swagger/ReDoc). Desactivar en producción.
OPEN_NOTEBOOK_PUBLIC_DOCS=false

# Solo activar si hay un proxy inverso (nginx, traefik) delante de la app.
OPEN_NOTEBOOK_TRUST_PROXY_HEADERS=false

# Bloqueo de URLs privadas/locales en las fuentes tipo enlace (protección SSRF).
OPEN_NOTEBOOK_ALLOW_PRIVATE_SOURCE_URLS=false


# ============================================================================
# HARDENING DE AUTENTICACIÓN
# ============================================================================

# Número máximo de intentos fallidos antes de bloquear la IP.
OPEN_NOTEBOOK_AUTH_MAX_ATTEMPTS=10

# Ventana de tiempo (segundos) para contar los intentos fallidos.
OPEN_NOTEBOOK_AUTH_WINDOW_SECONDS=300

# Tiempo de bloqueo (segundos) tras superar el máximo de intentos.
OPEN_NOTEBOOK_AUTH_BLOCK_SECONDS=600

# Retardo artificial (milisegundos) tras cada intento fallido (anti timing-attack).
OPEN_NOTEBOOK_AUTH_FAILURE_DELAY_MS=400


# ============================================================================
# LÍMITES DE SUBIDA
# ============================================================================

# Tamaño máximo de archivo en bytes (50 MB por defecto).
OPEN_NOTEBOOK_MAX_UPLOAD_BYTES=52428800


# ============================================================================
# OLLAMA — Modelo local de IA
# ============================================================================
# Apunta al Ollama instalado en el host Windows.
# host.docker.internal es el hostname especial de Docker Desktop que
# resuelve a la IP del host desde dentro de un contenedor.
#
# ⚠️  NUNCA apuntar a un endpoint remoto sin decisión consciente:
#     todo el texto enviado al modelo viajará por red.

OLLAMA_API_BASE=http://host.docker.internal:11434


# ============================================================================
# PROVEEDORES DE IA EXTERNOS — Dejar comentado si no se usan
# ============================================================================
# Es más seguro configurar las API keys desde la interfaz web de Open Notebook
# (Settings → API Keys) que definirlas aquí, ya que allí se cifran en BD.
# Solo descomentar si se necesita por razones de automatización.

# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
# GROQ_API_KEY=

# ============================================================================
# ENDPOINT OPENAI-COMPATIBLE — Dejar vacío o comentado si no se usa
# ============================================================================
# Si se descomentan con valores, Open Notebook intentará conectarse a ese
# endpoint y enviará datos. Dejar comentados = no hay conexión saliente.

# OPENAI_COMPATIBLE_BASE_URL=
# OPENAI_COMPATIBLE_API_KEY=


# ============================================================================
# COMPORTAMIENTO DE LA APLICACIÓN
# ============================================================================

# Desactivar comprobación automática de actualizaciones (evita llamadas
# salientes no solicitadas)
OPEN_NOTEBOOK_ENABLE_UPDATE_CHECK=false

# Procesamiento de contenido (valores por defecto razonables)
# CHUNK_SIZE=1500
# CHUNK_OVERLAP=150
